# FAgentLLM — Environment Variables Template
# Copy this file to .env and fill in your real values.

# ── Supabase (Database + Storage) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Frontend access (Vite)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Groq (Primary LLM: Qwen3-32B) ────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
QWEN_MODEL=qwen/qwen3-32b

# ── OpenRouter (Fallback LLM + OCR) ──────────────────────────────────────────
# Fallback activates automatically when Qwen3 fails or returns non-JSON
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FALLBACK_MODEL=baidu/cobuddy:free
OCR_MODEL=baidu/qianfan-ocr-fast:free

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET=change-me-in-production
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres
