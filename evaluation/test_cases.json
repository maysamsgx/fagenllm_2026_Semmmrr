  "metadata": {
    "version": "2.0",
    "created": "2026-05-15",
    "description": "FAgentLLM V4 held-out scientific evaluation suite. Ground truths defined BEFORE running the system. 50 cases stratified across 7 categories. Adversarial sensitivity analysis uses threshold-proximity and vendor-risk intensity as sensitivity parameters.",
    "total_cases": 50,
    "categories": {
      "clean_invoice": "TC-001 to TC-010 — baseline invoice flows, various amounts and departments",
      "duplicate_detection": "TC-011 to TC-016 — fraud prevention gate",
      "budget_enforcement": "TC-017 to TC-024 — spend control and hard-stop policy",
      "liquidity_gate": "TC-025 to TC-030 — cash position and AR forecast",
      "reconciliation_credit": "TC-031 to TC-038 — cross-domain causal chain",
      "adversarial_sensitivity": "TC-039 to TC-046 — adversarial threshold and risk sensitivity analysis",
      "governance_compliance": "TC-047 to TC-050 — cross-agent conflict and audit quality"
    },
    "path_matching": "Relative-order (causal-aware): all expected agents must appear in order, but extra agents between them are allowed.",
    "baseline_model": "Deterministic rule-only system: approves <$10k unconditionally, rejects >$100k unconditionally, no duplicate check, no cross-agent causal reasoning, no governance audit."
  },

