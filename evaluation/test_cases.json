  "metadata": {
    "version": "4.1",
    "created": "2026-05-16",
    "description": "System Functionality & Coordination Suite. This suite tests the empirical capability of the FAgentLLM architecture. It verifies that agents can extract data, route workflows correctly, share causal context across domains, and submit to a governance audit. It is designed for thesis PoC validation.",
    "total_cases": 15,
    "categories": {
      "straight_through": "TC-001 to TC-005 — Clean invoices testing the full multi-agent routing (Invoice -> Cash -> Budget -> Governance).",
      "budget_enforcement": "TC-006 to TC-009 — Tests the Budget Agent's ability to halt or alert on spend.",
      "causal_reconciliation": "TC-010 to TC-013 — Cross-domain causal links: Reconciliation anomalies triggering Credit risk adjustments.",
      "governance_audit": "TC-014 to TC-015 — Tests Governance agent actively blocking unapproved or risky traces."
    },
    "path_matching": "Relative-order (causal-aware): all expected agents must participate in the workflow.",
    "baseline_model": "Deterministic rule-only system (no cross-agent reasoning or governance)."
  },

